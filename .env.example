# 로컬 개발: docker-compose.yml로 Postgres 컨테이너를 띄운 뒤 아래 값을 사용한다.
#   docker compose up -d
DATABASE_URL="postgresql://meeet:meeet_local_dev@localhost:5434/meeet"

# 만료 폴 정리 Cron(GET /api/cron/cleanup) 보호용 시크릿(FR-13).
# 설정하면 해당 라우트는 `Authorization: Bearer <secret>` 헤더가 있어야 실행된다.
# Vercel Cron은 이 값을 자동으로 헤더에 실어 호출한다. 로컬에선 비워두면 인증 없이 호출 가능.
CRON_SECRET=""
